INSERT INTO SM_ACT
	VALUES ("cb34f8e9-e65b-4c4f-b359-87df5beb004c",
	"881bc3c3-ae8c-4e40-ab2c-057bcf2944c2",
	1,
	'//generate operation updateStatus toRestaurant
//delete Customer
//delete Order
create object instance table of TABL;
//Get all customers
select any cust from instances of CUST;
if (not_empty cust)
	//Find the related customer
	select one assignedCustomer related by table->CUST[R3];
	//Delete the relationship to the customer
	unrelate table from assignedCustomer across R3;
	//Delete the customer
	delete object instance assignedCustomer;
end if;

',
	'',
	0);
