INSERT INTO O_TFR
	VALUES ("9fae38b3-1022-4849-88b7-bbb4b53e909d",
	"22975cd6-ad7a-459c-9b9e-baaafa8095fb",
	'deleteTableWhenAvailable',
	'',
	"ba5eda7a-def5-0000-0000-000000000000",
	1,
	'//When table.current_State ="Available" generate event deleteTable
select many tabls from instances of TABL where (selected.current_state == Available);

select many tabls from instances of TABL ;
for each tabl in tabls
if (tabl.seatingAvailable == 4)
if (tabl.current_state == Available);
	generate event TABL2:deleteTable top tabl;
else
	//do nothing
end if;
end for;',
	1,
	'',
	"5641de7d-3d7f-4712-b2fe-181d98350124",
	0,
	2);
